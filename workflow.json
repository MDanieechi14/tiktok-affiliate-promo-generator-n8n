    {
      "parameters": {
        "jsCode": "// Fixed for Groq response structure\nconst rawText = $json.text || \"\";\n\n// Extract the JSON part\nlet cleanText = rawText.trim()\n  .replace(/```json|```/g, '')\n  .trim();\n\nlet parsed = {};\ntry {\n  parsed = JSON.parse(cleanText);\n} catch (e) {\n  // If parsing fails, try to extract manually (backup)\n  parsed = {\n    script: rawText,\n    caption: \"\",\n    hashtags: []\n  };\n}\n\nreturn [{\n  json: {\n    id: $json[\"ID\"] || \"\",\n    script: parsed.script || \"\",\n    caption: parsed.caption || \"\",\n    hashtags: Array.isArray(parsed.hashtags) \n      ? parsed.hashtags.join(\" \") \n      : (parsed.hashtags || \"\")\n  }\n}];"
      },
