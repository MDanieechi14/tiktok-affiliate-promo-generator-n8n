    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a TikTok Shop affiliate expert. Gumawa ng viral content sa Taglish para sa product na ito.\n\nProduct Name: {{ $json[\"Product Name\"] }}\nAffiliate Link: {{ $json[\"Affiliate Link\"] }}\nNiche: {{ $json[\"Niche\"] }}\nShort Description: {{ $json[\"Short Description\"] }}\n\nGumawa ng:\n- 1 maikling video script (15-30 seconds, may emojis at strong CTA)\n- 1 ready-to-post caption (Taglish, may link at CTA)\n- 5 magagandang hashtags\n\nReturn ONLY clean JSON, walang extra text:\n\n{\n  \"script\": \"dito ang script...\",\n  \"caption\": \"dito ang caption...\",\n  \"hashtags\": [\"#Hashtag1\", \"#Hashtag2\", ...]\n}",
        "batching": {}
